# Stop "LF will be replaced by CRLF" warnings by pinning line endings.
# Text files are stored with LF in the repo; git checkout normalizes per-OS.

* text=auto

# Source files: always LF (consistency across platforms)
*.mjs text eol=lf
*.js  text eol=lf
*.ts  text eol=lf
*.json text eol=lf
*.md  text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh  text eol=lf

# Windows-specific files: keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files: do not touch
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
