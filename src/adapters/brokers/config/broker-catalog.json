    "spokeo": {
      "displayName": "Spokeo",
      "category": "people-search",
      "jurisdiction": "US",
      "optOutUrl": null,
      "optOutMethod": "form",
      "adapterMode": "live",
      "live": {
        "endpointEnvVar": "SPOKEO_LIVE_ENDPOINT",
        "officialEndpointMode": "api"
      },
      "officialEndpoint": {
        "enabled": false,
        "api": {
          "endpointEnv": "SPOKEO_OFFICIAL_API_ENDPOINT",
          "endpoint": null,
          "method": "POST",
          "requiredFields": [
            "requestId",
            "action",
            "identityHints.fullName"
          ]
        },
        "form": {
          "endpointEnv": "SPOKEO_OFFICIAL_FORM_ENDPOINT",
          "endpoint": null,
          "method": "POST",
          "requiredFields": [
            "requestId",
            "identityHints"
          ]
        }
      },
      "rateLimitPolicy": {
        "requestsPerMinute": 6,
        "jitterMsMin": 250,
        "jitterMsMax": 1250,
        "backoff": "exponential"
      },
      "userAgentStrategy": {
        "mode": "declared-automation",
        "defaultUserAgent": "HolmesCleanup/0.1 compliance-contact"
      },
      "captchaToHumanQueue": {
        "enabled": true,
        "queue": "manualReview",
        "reason": "captcha_requires_human"
      },
      "complianceNotes": [
        "Use only official removal endpoints or broker-published forms.",
        "Do not bypass access controls, captchas, or terms gates.",
        "Log termsAccepted, lawfulBasis, and operatorId for each live official attempt."
      ],
      "template": {
        "keywords": "spokeo exposure",
        "notify": "none",
        "exportBeforeDelete": "ask"
      }
    },
